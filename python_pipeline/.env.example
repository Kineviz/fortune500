# ── Provider: "vertex", "openrouter", or "local" ───────────────────
LLM_PROVIDER=vertex

# ── Model (short name from MODEL_REGISTRY) ─────────────────────────
# Options: gemini-3.1-pro, gemini-3-flash, gemini-3.1-flash-lite,
#          qwen3.5-35b, qwen3.5-9b
MODEL_NAME=gemini-3-flash

# ── Google Vertex AI ────────────────────────────────────────────────
VERTEX_PROJECT=your-gcp-project-id
VERTEX_LOCATION=us-central1
GCS_BUCKET=gs://your-bucket-name

# ── OpenRouter ──────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...

# ── Local model (ollama / vllm / lmstudio) ─────────────────────────
LOCAL_LLM_URL=http://192.168.1.100:1234/v1

# ── Concurrency ────────────────────────────────────────────────────
MAX_CONCURRENT_REQUESTS=5

# ── Paths (defaults are fine for standard layout) ──────────────────
# DATA_DIR=../data_2021-2025
# OUTPUT_DIR=./output
# KUZU_DB_PATH=./sec_filings_db
